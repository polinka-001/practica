#include <bits/stdc++.h>
using namespace std;
 
vector<vector<int>> g;
vector<int> parent;
vector<bool> visited;
int target;
bool found = false;
 
void dfs(int v) {
    if (found) return;
    
    visited[v] = true;
    
    if (v == target) {
        found = true;
        return;
    }
    
    for (int to : g[v]) {
        if (!visited[to]) {
            parent[to] = v;
            dfs(to);
            if (found) return;
        }
    }
}
 
int main() {
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);
    
    int n, m, u, v;
    cin >> n >> m >> u >> v;
    
    g.assign(n + 1, {});
    for (int i = 0; i < m; i++) {
        int a, b;
        cin >> a >> b;
        g[a].push_back(b);
        g[b].push_back(a);
    }
    
    parent.assign(n + 1, -1);
    visited.assign(n + 1, false);
    target = v;
    
    dfs(u);
    
    if (!found) {
        cout << -1 << "\n";
        return 0;
    }
    
    vector<int> path;
    int cur = v;
    while (cur != -1) {
        path.push_back(cur);
        cur = parent[cur];
    }
    
    reverse(path.begin(), path.end());
    
    for (int vertex : path) {
        cout << vertex << " ";
    }
    cout << "\n";
    
    return 0;
}
