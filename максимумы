#include <bits/stdc++.h>
using namespace std;
 
int main() {
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);
    
    int n;
    cin >> n;
    
    vector<long long> a(n);
    for (int i = 0; i < n; i++) {
        cin >> a[i];
    }
    
    vector<int> prev_greater(n, -1);
    vector<int> next_greater_or_equal(n, n);
    
    stack<int> st;
    
    for (int i = 0; i < n; i++) {
        while (!st.empty() && a[st.top()] <= a[i]) {
            st.pop();
        }
        prev_greater[i] = st.empty() ? -1 : st.top();
        st.push(i);
    }
    
    while (!st.empty()) st.pop();
    
    for (int i = n - 1; i >= 0; i--) {
        while (!st.empty() && a[st.top()] < a[i]) {
            st.pop();
        }
        next_greater_or_equal[i] = st.empty() ? n : st.top();
        st.push(i);
    }
    
    long long ans = 0;
    for (int i = 0; i < n; i++) {
        long long left_count = i - prev_greater[i];
        long long right_count = next_greater_or_equal[i] - i;
        ans += a[i] * left_count * right_count;
    }
    
    cout << ans << "\n";
    
    return 0;
}
