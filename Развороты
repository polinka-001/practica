#include <bits/stdc++.h>
using namespace std;
 
int main() {
    ios::sync_with_stdio(false);
    cin.tie(nullptr);
    
    int n;
    cin >> n;
    
    vector<int> a(n);
    for (int i = 0; i < n; i++) {
        cin >> a[i];
    }
    
    int l, r;
    while (cin >> l >> r) {
        if (l == 0 && r == 0) {
            break;
        }
        l--;
        r--;
        reverse(a.begin() + l, a.begin() + r + 1);
    }
    
    for (int i = 0; i < n; i++) {
        cout << a[i] << ' ';
    }
    cout << '\n';
    
    return 0;
}
