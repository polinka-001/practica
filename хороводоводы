#include <bits/stdc++.h>
using namespace std;
 
const long long MOD = 1000000007LL;
 
int main() {
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);
    
    int n;
    cin >> n;
    
    long long ans = 1;
    for (int i = 2; i <= n - 1; i++) {
        ans = (ans * i) % MOD;
    }
    
    ans = ans * ((MOD + 1) / 2) % MOD;
    
    cout << ans << "\n";
    
    return 0;
}
