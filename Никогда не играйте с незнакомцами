#include <bits/stdc++.h>
using namespace std;
 
int main() {
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);
    
    int n;
    cin >> n;
    
    vector<long long> cards(n);
    for (int i = 0; i < n; i++) {
        cin >> cards[i];
    }
    
    sort(cards.begin(), cards.end());
    
    bool isValid = true;
    for (int i = 1; i < n; i++) {
        if (cards[i] - cards[i-1] != 1) {
            isValid = false;
            break;
        }
    }
    
    cout << (isValid ? "Deck looks good" : "Scammed") << '\n';
    
    return 0;
}
