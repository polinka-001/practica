#include <iostream>
 
using namespace std;
using int64 = long long;
 
int main() {
    ios::sync_with_stdio(false);
    cin.tie(nullptr);
 
    int64 n, k;
    cin >> n >> k;
 
    if (k == 0) {
        if (n == 0) {
            cout << -1 << '\n';
            return 0;
        }
        int64 ans = (n & 1) ? n : n - 1;
        cout << ans << '\n';
        return 0;
    }
 
    if (k > 63) {
        cout << -1 << '\n';
        return 0;
    }
    int64 p = 1LL << k;
    if (n <= p) {
        cout << -1 << '\n';
        return 0;
    }
 
    int64 q = n / p;
    int64 t = (q & 1) ? q : q - 1;
    int64 ans = p * t;
    cout << ans << '\n';
 
    return 0;
}
