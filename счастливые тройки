#include <bits/stdc++.h>
using namespace std;
 
int main() {
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);
    
    int n;
    long long k;
    cin >> n >> k;
    
    vector<long long> a(n);
    for (int i = 0; i < n; i++) {
        cin >> a[i];
    }
    
    sort(a.begin(), a.end());
    
    long long ans = 0;
    int r = 0;
    
    for (int l = 0; l < n; l++) {
        while (r < n && a[r] - a[l] <= k) {
            r++;
        }
        
        long long cnt = r - l - 1;
        if (cnt >= 2) {
            ans += cnt * (cnt - 1) / 2;
        }
    }
    
    cout << ans << "\n";
    
    return 0;
}
