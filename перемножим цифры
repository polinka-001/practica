#include <bits/stdc++.h>
using namespace std;
 
string solve(long long n) {
    if (n == 0) return "10";
    if (n == 1) return "1";
    
    vector<int> digits;
    
    for (int d = 9; d >= 2; d--) {
        while (n % d == 0) {
            digits.push_back(d);
            n /= d;
        }
    }
    
    if (n != 1) return "-1";
    
    sort(digits.begin(), digits.end());
    
    string ans;
    for (int d : digits) {
        ans += to_string(d);
    }
    
    return ans;
}
 
int main() {
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);
    
    int t;
    cin >> t;
    
    while (t--) {
        long long n;
        cin >> n;
        cout << solve(n) << "\n";
    }
    
    return 0;
}
