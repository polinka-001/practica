#include <iostream>
using namespace std;
 
int main() {
    long long n, a0;
    cin >> n >> a0;
 
    long long mod = 1000000007;
 
    long long x = a0;
 
    long long max1 = -1;
    long long max2 = -1;
 
    for (int i = 1; i <= n; i++) {
        x = x * 5 % mod;
 
        if (x > max1) {
            max2 = max1;
            max1 = x;
        } else if (x > max2) {
            max2 = x;
        }
    }
 
    cout << max2 << " " << max1;
 
    return 0;
}
