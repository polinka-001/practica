#include <bits/stdc++.h>
using namespace std;
 
int main() {
    ios::sync_with_stdio(false);
    cin.tie(nullptr);
    
    int x1, y1, x2, y2;
    int x3, y3, x4, y4;
    
    cin >> x1 >> y1 >> x2 >> y2;
    cin >> x3 >> y3 >> x4 >> y4;
    
    int left = max(min(x1, x2), min(x3, x4));
    int right = min(max(x1, x2), max(x3, x4));
    int bottom = max(min(y1, y2), min(y3, y4));
    int top = min(max(y1, y2), max(y3, y4));
    
    int area1 = abs(x1 - x2) * abs(y1 - y2);
    int area2 = abs(x3 - x4) * abs(y3 - y4);
    
    int intersect = 0;
    if (left < right && bottom < top) {
        intersect = (right - left) * (top - bottom);
    }
    
    cout << area1 + area2 - intersect << '\n';
    
    return 0;
}
