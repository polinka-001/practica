#include <bits/stdc++.h>
using namespace std;
 
int main() {
    ios::sync_with_stdio(false);
    cin.tie(nullptr);
    
    int n;
    cin >> n;
    
    vector<long long> a(n);
    for (int i = 0; i < n; i++) {
        cin >> a[i];
    }
    
    vector<int> local_min, local_max;
    int min_pos = 0, max_pos = 0;
    
    for (int i = 0; i < n; i++) {
        if (a[i] < a[min_pos]) min_pos = i;
        if (a[i] > a[max_pos]) max_pos = i;
        
        bool left_ok = (i == 0) || (i > 0 && a[i] != a[i-1]);
        bool right_ok = (i == n-1) || (i < n-1 && a[i] != a[i+1]);
        
        if (left_ok && right_ok) {
            bool is_min = (i == 0 || a[i] < a[i-1]) && (i == n-1 || a[i] < a[i+1]);
            bool is_max = (i == 0 || a[i] > a[i-1]) && (i == n-1 || a[i] > a[i+1]);
            
            if (is_min) local_min.push_back(i + 1);
            if (is_max) local_max.push_back(i + 1);
        }
    }
    
    cout << local_min.size();
    for (int pos : local_min) cout << ' ' << pos;
    cout << '\n';
    
    cout << local_max.size();
    for (int pos : local_max) cout << ' ' << pos;
    cout << '\n';
    
    cout << min_pos + 1 << ' ' << max_pos + 1 << '\n';
    
    return 0;
}
