#include <bits/stdc++.h>
using namespace std;
 
const long long MOD = 1000000007LL;
 
int main() {
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);
    
    int n, k, m;
    cin >> n >> k >> m;
    
    vector<bool> dangerous(n + 1, false);
    for (int i = 0; i < m; i++) {
        int x;
        cin >> x;
        dangerous[x] = true;
    }
    
    vector<long long> dp(n + 1, 0);
    long long window_sum = 0;
    dp[0] = 1;
    
    for (int i = 1; i <= n; i++) {
        window_sum = (window_sum + dp[i - 1]) % MOD;
        
        if (i - k - 1 >= 0) {
            window_sum = (window_sum - dp[i - k - 1] + MOD) % MOD;
        }
        
        if (!dangerous[i]) {
            dp[i] = window_sum;
        } else {
            dp[i] = 0;
        }
    }
    
    cout << dp[n] << "\n";
    
    return 0;
}
