#include <bits/stdc++.h>
using namespace std;
 
int main() {
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);
    
    int n, m;
    cin >> n >> m;
    
    vector<vector<int>> a(n, vector<int>(m));
    for (int i = 0; i < n; i++) {
        for (int j = 0; j < m; j++) {
            cin >> a[i][j];
        }
    }
    
    vector<vector<int>> dp(n, vector<int>(m));
    
    for (int i = 0; i < n; i++) {
        for (int j = 0; j < m; j++) {
            dp[i][j] = a[i][j];
            
            if (i == 0 && j == 0) continue;
            
            int mx = 0;
            if (i > 0) mx = max(mx, dp[i-1][j]);
            if (j > 0) mx = max(mx, dp[i][j-1]);
            if (i > 0 && j > 0) mx = max(mx, dp[i-1][j-1]);
            
            dp[i][j] += mx;
        }
    }
    
    cout << dp[n-1][m-1] << "\n";
    
    return 0;
}
